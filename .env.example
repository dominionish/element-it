# Copy this file to .env and fill secrets locally or on the deploy server.
# Do not commit the real .env file.

TZ=Europe/Moscow

# n8n
N8N_IMAGE=n8nio/n8n:2.25.4
N8N_VERSION=2.25.4
N8N_HOST=localhost
N8N_HOST_PORT=5678
N8N_LISTEN_ADDRESS=0.0.0.0
N8N_PROTOCOL=http
N8N_SECURE_COOKIE=false
N8N_ENCRYPTION_KEY=

# Transcriber
TRANSCRIBER_HOST_PORT=7861
TRANSCRIBER_IMAGE=ghcr.io/dominionish/element-it/transcriber:latest

# A Planfix "comment added" scenario sends attachments to /planfix/comment-audio.
# /planfix/audio-parse remains a compatible alias. Receiving audio needs no API token.
PLANFIX_AUDIO_EXTENSIONS=.mp3,.m4a,.wav,.ogg,.opus,.webm,.aac,.flac,.mp4,.mov,.mkv,.avi
PLANFIX_CREATE_TRANSCRIBE_JOBS=true
PLANFIX_ALLOWED_FILE_URL_HOSTS=planfix.ru,.planfix.ru
PLANFIX_FILE_URL_TIMEOUT=120

# Preferred result delivery: send TXT as multipart/form-data to a POST incoming webhook.
PLANFIX_RESULT_WEBHOOK_ID=
PLANFIX_RESULT_WEBHOOK_URL=
PLANFIX_RESULT_FILE_FIELD=txt_file
PLANFIX_RESULT_TIMEOUT=120
PLANFIX_ALLOWED_RESULT_HOSTS=planfix.ru,.planfix.ru

# GPU runtime for production compose.
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
