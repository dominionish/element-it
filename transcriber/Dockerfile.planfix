FROM python:3.12-slim-bookworm

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DEFAULT_TIMEOUT=120 \
    PIP_RETRIES=10

WORKDIR /app
COPY requirements-planfix.txt /app/requirements-planfix.txt
RUN python -m pip install --upgrade pip \
    && python -m pip install -r /app/requirements-planfix.txt
COPY app/planfix_service.py /app/planfix_service.py

EXPOSE 7862
CMD ["uvicorn", "planfix_service:app", "--host", "0.0.0.0", "--port", "7862"]
